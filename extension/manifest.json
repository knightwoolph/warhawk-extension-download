{
  "manifest_version": 3,
  "name": "Warhawk",
  "version": "1.9.4",
  "description": "Facebook Marketplace posting automation — browser runtime",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://pjjzskcjynsgdvnunyxf.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/create/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/marketplace/item/*"],
      "js": ["delete-handler/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/marketplace/item/*"],
      "js": ["scrape-marketplace/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/marketplace/item/*"],
      "js": ["snapshot-scraper/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://warhawk-platform.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["bridge/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
